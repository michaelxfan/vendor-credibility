# Supabase (from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Either the anon/publishable key (read-only dashboard, relies on public_read RLS policy)...
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# ...or the service role key (required for POST/DELETE via /api/assessments).
# When both are set, service role takes precedence.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: secret for write endpoints (POST/DELETE). If unset, writes are open (local dev).
VC_API_SECRET=your_long_random_secret_here
